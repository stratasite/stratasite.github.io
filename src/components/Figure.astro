---
// Reusable figure for article/feature MDX: image or video with optional caption.
// Use inside MDX: <Figure src="/path.png" caption="..." />
//                 <Figure video="/clip.mp4" caption="..." />
interface Props {
  src?: string;
  video?: string;
  alt?: string;
  caption?: string;
}
const { src, video, alt = '', caption } = Astro.props;
---

<figure class="not-prose my-8">
  {src && <img src={src} alt={alt} class="w-full rounded-lg border border-border" loading="lazy" />}
  {
    video && (
      <video class="w-full rounded-lg border border-border" autoplay loop muted playsinline>
        <source src={video} type="video/mp4" />
      </video>
    )
  }
  {caption && <figcaption class="mt-3 text-center text-sm text-muted-foreground">{caption}</figcaption>}
</figure>
