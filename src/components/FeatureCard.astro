---
interface Props {
  title: string;
  summary: string;
  href: string;
  image?: string;
}
const { title, summary, href, image } = Astro.props;
---

<article class="group flex flex-col overflow-hidden rounded-lg border border-border bg-surface transition-shadow hover:shadow-lg">
  <div class="aspect-[16/9] overflow-hidden bg-surface-2">
    {
      image ? (
        <img src={image} alt="" class="h-full w-full object-cover" />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-strata-peach/40 to-primary/20">
          <span class="font-display text-sm font-semibold text-muted-foreground">{title}</span>
        </div>
      )
    }
  </div>
  <div class="flex flex-1 flex-col p-6">
    <h3 class="font-display text-lg font-bold tracking-tight">{title}</h3>
    <p class="mt-2 flex-1 text-sm text-muted-foreground">{summary}</p>
    <a
      href={href}
      class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary group-hover:gap-2 transition-all"
    >
      Learn more
      <svg class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.17 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
      </svg>
    </a>
  </div>
</article>
