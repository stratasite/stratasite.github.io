---
// The agent validation loop: an agent (or analyst) proposes a partial query,
// Strata validates it and returns the same structured contract every step
// (valid?, compatible next steps, structured reject), the agent refines, and
// the loop repeats until a completed query executes into a grain-safe result.
// Full version for the article; `mini` for the homepage row. Brand tokens only.
const botIcon = `<rect x="4" y="8" width="16" height="11" rx="3"/><path d="M12 8V4"/><circle cx="12" cy="3" r="1"/><path d="M9 13v1.5"/><path d="M15 13v1.5"/>`;

interface Props {
  mini?: boolean;
}
const { mini = false } = Astro.props;
---

{
  mini ? (
    <figure class="aloop aloop-mini mx-auto w-full max-w-md" aria-label="The agent validation loop">
      <svg viewBox="0 0 480 360" role="img" class="h-auto w-full">
        <title>An agent proposes a partial query, Strata validates and responds, the loop repeats into a grain-safe answer.</title>
        <defs>
          <marker id="al-m-arrow" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto">
            <path class="arrowhead" d="M0 0 L0 9 L7 4.5 Z" />
          </marker>
        </defs>

        {/* loop arrows */}
        <path class="flow" d="M176 116 C 240 92, 300 92, 300 116" marker-end="url(#al-m-arrow)" />
        <path class="flow" d="M300 156 C 300 180, 240 180, 176 156" marker-end="url(#al-m-arrow)" />
        <text class="edge" x="238" y="82" text-anchor="middle">partial query</text>
        <text class="edge" x="238" y="198" text-anchor="middle">valid? · next · reject</text>
        <text class="loop" x="238" y="140" text-anchor="middle">↻</text>

        {/* agent */}
        <rect class="node" x="26" y="104" width="150" height="64" rx="13" />
        <svg x="44" y="124" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ic" set:html={botIcon} />
        <text class="name" x="80" y="141">Agent</text>

        {/* strata */}
        <rect class="hub" x="300" y="98" width="156" height="76" rx="15" />
        <text class="hub-title" x="378" y="132" text-anchor="middle">strata</text>
        <text class="hub-sub" x="378" y="152" text-anchor="middle">validate</text>

        {/* exit to answer */}
        <line class="exit" x1="378" y1="174" x2="378" y2="250" marker-end="url(#al-m-arrow)" />
        <rect class="answer" x="276" y="250" width="204" height="50" rx="12" />
        <text class="ans" x="378" y="280" text-anchor="middle">grain-safe answer</text>
      </svg>
    </figure>
  ) : (
    <figure class="aloop mx-auto w-full max-w-3xl" aria-label="The agent validation loop">
      <svg viewBox="0 0 820 376" role="img" class="h-auto w-full">
        <title>An agent proposes a partial query, Strata validates and returns a structured response, the loop repeats until a completed query executes into a grain-safe result.</title>
        <defs>
          <marker id="al-arrow" markerWidth="9" markerHeight="9" refX="7" refY="4.5" orient="auto">
            <path class="arrowhead" d="M0 0 L0 9 L7 4.5 Z" />
          </marker>
        </defs>

        {/* request (top) */}
        <path class="flow" d="M244 146 C 360 112, 460 112, 576 146" marker-end="url(#al-arrow)" />
        <text class="edge" x="410" y="98" text-anchor="middle">partial query</text>
        <text class="edge-sub" x="410" y="116" text-anchor="middle">a proposed measure, dimension, or filter</text>

        {/* response (bottom) */}
        <path class="flow" d="M576 180 C 460 214, 360 214, 244 180" marker-end="url(#al-arrow)" />
        <text class="edge" x="410" y="238" text-anchor="middle">valid?  ·  compatible next steps  ·  structured reject</text>

        {/* loop hint */}
        <text class="loop" x="410" y="156" text-anchor="middle">↻</text>
        <text class="edge-sub" x="410" y="176" text-anchor="middle">repeat until the query is complete</text>

        {/* agent */}
        <rect class="node" x="48" y="118" width="196" height="88" rx="15" />
        <svg x="70" y="146" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ic" set:html={botIcon} />
        <text class="name" x="108" y="156">Agent</text>
        <text class="name-sub" x="108" y="178">or analyst</text>

        {/* strata */}
        <rect class="hub" x="576" y="110" width="200" height="100" rx="16" />
        <text class="hub-title" x="676" y="150" text-anchor="middle">strata</text>
        <text class="hub-sub" x="676" y="172" text-anchor="middle">validate</text>
        <text class="hub-sub2" x="676" y="192" text-anchor="middle">grain + compatibility</text>

        {/* exit to answer */}
        <line class="exit" x1="676" y1="210" x2="676" y2="298" marker-end="url(#al-arrow)" />
        <text class="exit-lbl" x="692" y="258">when complete</text>
        <rect class="answer" x="560" y="298" width="232" height="58" rx="13" />
        <text class="ans" x="676" y="324" text-anchor="middle">grain-safe result</text>
        <text class="ans-sub" x="676" y="343" text-anchor="middle">correct, at the right grain</text>
      </svg>
    </figure>
  )
}

<style>
  .aloop .arrowhead {
    fill: var(--strata-peach);
  }
  .aloop .flow {
    fill: none;
    stroke: var(--strata-peach);
    stroke-width: 2;
    stroke-dasharray: 6 7;
    animation: aloop-flow 2s linear infinite;
  }
  .aloop .node {
    fill: color-mix(in srgb, var(--strata-cream) 5%, transparent);
    stroke: color-mix(in srgb, var(--strata-cream) 22%, transparent);
    stroke-width: 1.2;
  }
  .aloop .ic {
    stroke: var(--strata-peach);
  }
  .aloop .name {
    fill: var(--strata-cream);
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 600;
  }
  .aloop-mini .name {
    font-size: 15px;
  }
  .aloop .name-sub {
    fill: color-mix(in srgb, var(--strata-cream) 62%, transparent);
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
  }
  .aloop .hub {
    fill: var(--strata-peach);
  }
  .aloop .hub-title {
    fill: var(--strata-rust-deep);
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
  }
  .aloop .hub-sub {
    fill: var(--strata-rust-deep);
    font-family: var(--font-display);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
  .aloop .hub-sub2 {
    fill: color-mix(in srgb, var(--strata-rust-deep) 78%, transparent);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
  }
  .aloop .edge {
    fill: var(--strata-cream);
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 600;
  }
  .aloop-mini .edge {
    font-size: 12px;
  }
  .aloop .edge-sub {
    fill: color-mix(in srgb, var(--strata-cream) 66%, transparent);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
  }
  .aloop .loop {
    fill: var(--strata-peach);
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 700;
  }
  .aloop .exit {
    fill: none;
    stroke: var(--strata-peach);
    stroke-width: 2;
  }
  .aloop .exit-lbl {
    fill: color-mix(in srgb, var(--strata-cream) 66%, transparent);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
  }
  .aloop .answer {
    fill: color-mix(in srgb, var(--strata-peach) 10%, transparent);
    stroke: color-mix(in srgb, var(--strata-peach) 40%, transparent);
    stroke-width: 1.2;
  }
  .aloop .ans {
    fill: var(--strata-cream);
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
  }
  .aloop .ans-sub {
    fill: color-mix(in srgb, var(--strata-cream) 66%, transparent);
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
  }

  @keyframes aloop-flow {
    to {
      stroke-dashoffset: -26;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .aloop .flow {
      animation: none;
    }
  }
</style>
