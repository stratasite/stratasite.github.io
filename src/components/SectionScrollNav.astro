---
interface Props {
  sections: { id: string; label: string }[];
}
const { sections } = Astro.props;
---

{
  sections.length > 0 && (
    <nav class="scroll-nav sticky top-24 hidden text-sm lg:block" aria-label="On this page">
      <p class="mb-3 font-display text-xs font-semibold uppercase tracking-wider text-muted-foreground">
        On this page
      </p>
      <ul class="space-y-1 border-l border-border">
        {sections.map((s) => (
          <li>
            <a
              href={`#${s.id}`}
              data-scroll-link={s.id}
              class="-ml-px block border-l border-transparent py-1.5 pl-4 text-muted-foreground transition-colors hover:text-foreground"
            >
              {s.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}

<script>
  // Scroll-spy: highlight the jump link for the section currently in view.
  const links = Array.from(
    document.querySelectorAll<HTMLAnchorElement>('[data-scroll-link]')
  );
  if (links.length) {
    const active = 'text-foreground !border-primary font-medium';
    const byId = new Map(links.map((l) => [l.dataset.scrollLink!, l]));
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            links.forEach((l) => l.classList.remove(...active.split(' ')));
            byId.get(entry.target.id)?.classList.add(...active.split(' '));
          }
        });
      },
      { rootMargin: '-20% 0px -70% 0px', threshold: 0 }
    );
    byId.forEach((_, id) => {
      const el = document.getElementById(id);
      if (el) observer.observe(el);
    });
  }
</script>
