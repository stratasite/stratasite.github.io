---
// Capability comparison seeded from STRATA.md §5.1. Re-verify competitor cells
// before each publish (competitor features evolve — see STRATA.md §9.4).
const competitors = ['Strata', 'Snowflake', 'MetricFlow', 'Cube', 'Looker'];

const rows: { capability: string; cells: string[] }[] = [
  { capability: 'Cross-fact blending', cells: ['Automatic (naming + blend groups)', 'Join-based; same-name dims break', 'Semi-auto via entities', 'Authored views', 'Merged results'] },
  { capability: 'Performance architecture', cells: ['Aggregate-aware + federated OLAP', 'Warehouse-native (Snowflake only)', 'Warehouse-bound', 'Managed pre-aggregations', 'PDTs / agg awareness'] },
  { capability: 'Partition-aware hot-tier routing', cells: ['Native', 'No', 'No', 'Partial', 'Partial'] },
  { capability: 'Warehouse independence', cells: ['Any engine', 'Snowflake only', 'Multi', 'Multi', 'Many dialects'] },
  { capability: 'RLS & masking', cells: ['Built in', 'Native, strong', 'Via warehouse', 'Built in', 'Built in'] },
  { capability: 'Measure expressiveness', cells: ['Leads (5 measure types)', 'LOD limited', 'Partial', 'Weak', 'Weak'] },
  { capability: 'Built-in self-service & dashboards', cells: ['Yes — beautiful by default', 'No', 'No', 'No (headless)', 'Yes (full BI)'] },
  { capability: 'Interactive query-build feedback', cells: ['Per keystroke + AI-assisted', 'No', 'No', 'No', 'Partial'] },
  { capability: 'Battle-tested at scale', cells: ['4+ yrs, Netflix scale', 'GA 2026, new', 'Proven', 'Proven', 'Proven'] },
];
---

<div class="overflow-x-auto rounded-lg border border-border">
  <table class="w-full min-w-[48rem] border-collapse text-left text-sm tnum">
    <thead>
      <tr class="bg-surface-2">
        <th class="px-4 py-3 font-display font-semibold">Capability</th>
        {competitors.map((c, i) => (
          <th class={`px-4 py-3 font-display font-semibold ${i === 0 ? 'text-primary' : 'text-muted-foreground'}`}>{c}</th>
        ))}
      </tr>
    </thead>
    <tbody>
      {rows.map((row, ri) => (
        <tr class={ri % 2 ? 'bg-surface' : 'bg-background'}>
          <th scope="row" class="px-4 py-3 font-medium text-foreground">{row.capability}</th>
          {row.cells.map((cell, ci) => (
            <td class={`px-4 py-3 align-top ${ci === 0 ? 'font-medium text-foreground' : 'text-muted-foreground'}`}>{cell}</td>
          ))}
        </tr>
      ))}
    </tbody>
  </table>
</div>
