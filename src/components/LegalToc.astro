---
/**
 * Contents nav for a legal document. Entries come from the numbering plugin
 * (see src/plugins/rehype-legal-sections.mjs), so the numbers here are the same
 * ones rendered in the body — they can't drift apart.
 *
 * Legal documents run long (dozens of sections), so this scrolls inside a
 * sticky column on desktop and collapses into a disclosure on mobile.
 */
interface Props {
  toc: { id: string; label: string; text: string; depth: number }[];
}
const { toc } = Astro.props;

const linkClass =
  'block rounded py-1 text-muted-foreground transition-colors hover:text-foreground';
---

{
  toc.length > 0 && (
    <>
      {/* Mobile: collapsed by default so the document itself stays above the fold. */}
      <details class="mb-10 rounded-lg border border-border bg-surface-2 p-4 lg:hidden">
        <summary class="cursor-pointer font-display text-sm font-semibold tracking-tight text-foreground">
          Contents
        </summary>
        <ul class="mt-3 space-y-0.5 text-sm">
          {toc.map((s) => (
            <li class={s.depth > 2 ? 'pl-4' : ''}>
              <a href={`#${s.id}`} class={linkClass}>
                <span class="tnum mr-2 text-primary">{s.label}</span>
                {s.text}
              </a>
            </li>
          ))}
        </ul>
      </details>

      <nav
        class="sticky top-24 hidden max-h-[calc(100vh-8rem)] overflow-y-auto pr-2 text-sm lg:block"
        aria-label="Contents"
      >
        <p class="mb-3 font-display text-xs font-semibold uppercase tracking-wider text-muted-foreground">
          Contents
        </p>
        <ul class="space-y-0.5 border-l border-border pl-4">
          {toc.map((s) => (
            <li class={s.depth > 2 ? 'pl-3' : ''}>
              <a href={`#${s.id}`} class={`${linkClass} ${s.depth > 2 ? 'text-[0.8125rem]' : 'font-medium'}`}>
                <span class="tnum mr-2 text-primary">{s.label}</span>
                {s.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </>
  )
}
