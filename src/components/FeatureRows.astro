---
// Alternating (zigzag) feature rows. Borderless / soft. The only "travel down"
// affordance is a gentle reveal-on-scroll (fade + rise) plus a large faint
// ghost number per row for sequence. No rails, lines, or nodes.
import type { CollectionEntry } from 'astro:content';
import FeatureVisual from './FeatureVisual.astro';

interface Props {
  features: CollectionEntry<'features'>[];
}
const { features } = Astro.props;
---

<div class="mx-auto max-w-6xl space-y-20 lg:space-y-28">
  {
    features.map((f, i) => {
      const flip = i % 2 === 1;
      const n = String(i + 1).padStart(2, '0');
      return (
        <div class="grid items-center gap-8 lg:grid-cols-2 lg:gap-16" data-reveal>
          <div class={flip ? 'lg:order-2' : ''}>
            <FeatureVisual index={i} title={f.data.title} image={f.data.image} video={f.data.video} diagram={f.data.diagram} />
          </div>

          <div class={`relative ${flip ? 'lg:order-1' : ''}`}>
            <span class="fr-num" aria-hidden="true">{n}</span>
            <h3 class="relative font-display text-2xl font-bold tracking-tight sm:text-3xl">
              {f.data.title}
            </h3>
            <p class="relative mt-3 text-[1.05rem] leading-relaxed text-muted-foreground">
              {f.data.summary}
            </p>
            <a
              href={`/features/${f.slug}/`}
              class="group/link relative mt-5 inline-flex items-center gap-1 font-medium text-primary"
            >
              Learn more
              <svg class="h-4 w-4 transition-transform group-hover/link:translate-x-1" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.17 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
              </svg>
            </a>
          </div>
        </div>
      );
    })
  }
</div>

<style>
  .fr-num {
    position: absolute;
    top: -2.4rem;
    left: -0.5rem;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 5rem;
    line-height: 1;
    color: color-mix(in srgb, var(--strata-peach) 55%, transparent);
    z-index: 0;
    pointer-events: none;
  }

  [data-reveal] {
    opacity: 0;
    transform: translateY(24px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }
  [data-reveal].in {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-reveal] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('in');
          io.unobserve(e.target);
        }
      });
    },
    { rootMargin: '0px 0px -10% 0px', threshold: 0.1 }
  );
  document.querySelectorAll('[data-reveal]').forEach((el) => io.observe(el));
</script>
