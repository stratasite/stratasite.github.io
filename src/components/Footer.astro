---
import { getCollection } from 'astro:content';
import { nav, site } from '../config/site';

const features = (await getCollection('features', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const comparisons = (await getCollection('compare', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const caseStudies = (await getCollection('casestudies', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
// Legal documents sit in the bottom bar next to the copyright — the place
// people look for them, and a stable home as more documents are added.
const legalDocs = (await getCollection('legal', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const year = new Date().getFullYear();
---

<footer class="bg-strata-ink text-strata-cream">
  <div class="mx-auto grid max-w-7xl gap-10 px-4 py-14 sm:px-6 md:grid-cols-4 lg:px-8">
    <div class="md:col-span-1">
      <div class="flex items-center gap-2.5">
        <img src="/brand/assets/strata_mark_dark.svg" alt="" class="h-7 w-auto" />
        <span class="font-display text-lg font-bold tracking-tight">strata</span>
      </div>
      <p class="mt-3 max-w-xs text-sm text-muted-foreground">{site.description}</p>
    </div>

    <div>
      <h3 class="text-sm font-semibold text-foreground">Product</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {features.map((f) => (
          <li><a class="text-muted-foreground hover:text-foreground" href={`/features/${f.slug}/`}>{f.data.title}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold text-foreground">Compare</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {comparisons.map((c) => (
          <li><a class="text-muted-foreground hover:text-foreground" href={`/compare/${c.slug}/`}>{c.data.title}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-semibold text-foreground">Resources</h3>
      <ul class="mt-3 space-y-2 text-sm">
        {caseStudies.map((cs) => (
          <li><a class="text-muted-foreground hover:text-foreground" href={`/case-studies/${cs.slug}/`}>{cs.data.navLabel ?? cs.data.title}</a></li>
        ))}
        <li><a class="text-muted-foreground hover:text-foreground" href="/pricing/">Pricing</a></li>
        <li><a class="text-muted-foreground hover:text-foreground" href={site.docsUrl} target="_blank" rel="noopener">Docs</a></li>
        <li><a class="text-muted-foreground hover:text-foreground" href={site.blogUrl} target="_blank" rel="noopener">Blog</a></li>
        <li><a class="text-muted-foreground hover:text-foreground" href={site.demoUrl} target="_blank" rel="noopener" data-cta="demo" data-cta-location="footer">{site.demoLabel}</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-border">
    <div class="mx-auto flex max-w-7xl flex-col gap-3 px-4 py-6 text-xs text-muted-foreground sm:flex-row sm:items-center sm:justify-between sm:px-6 lg:px-8">
      <p>© {year} Strata Business Intelligence, LLC · Born at Netflix, ready for the world</p>
      <ul class="flex flex-wrap items-center gap-x-5 gap-y-2">
        {legalDocs.map((d) => (
          <li>
            <a class="hover:text-foreground" href={`/legal/${d.slug}/`}>{d.data.navLabel ?? d.data.title}</a>
          </li>
        ))}
        <li><a class="hover:text-foreground" href="/legal/">Legal</a></li>
      </ul>
    </div>
  </div>
</footer>
