---
// "How we stack up" — a tabbed, conversion-focused comparison. Strata spans two
// categories (STRATA.md §5), so visitors self-select their frame and see the
// sharpest "them -> Strata" contrast for it. Deep-dive links are pulled from the
// `compare` collection by `category`. The exhaustive matrix lives on those
// detail pages, not here.
import type { CollectionEntry } from 'astro:content';
import CtaButton from './CtaButton.astro';

interface Props {
  comparisons: CollectionEntry<'compare'>[];
}
const { comparisons } = Astro.props;

const tabs = [
  {
    key: 'semantic-layer',
    label: 'vs Semantic Layers',
    who: [
      { label: 'dbt / MetricFlow', slug: 'strata-vs-metricflow' },
      { label: 'Cube', slug: 'strata-vs-cube' },
      { label: 'Snowflake Semantic Views', slug: 'strata-vs-semantic-views' },
    ],
    lineThem: 'They hand you a model.',
    lineStrata: 'Strata hands you answers.',
    rows: [
      { axis: 'Consumption', them: 'Headless. Bring your own BI tool.', strata: 'Beautiful self-service and dashboards, built in' },
      { axis: 'Blending', them: 'Author every queryable combination', strata: 'Automatic and grain-safe, by naming' },
      { axis: 'Performance', them: 'Bound to a single warehouse', strata: 'Federated hot tiers, sub-second' },
      { axis: 'For agents', them: 'You build the retrieval API', strata: 'The validation loop is the agent API' },
    ],
  },
  {
    key: 'bi-tool',
    label: 'vs BI Tools',
    who: [
      { label: 'Looker', slug: 'strata-vs-looker' },
      { label: 'Tableau', slug: 'strata-vs-tableau' },
      { label: 'Power BI', slug: 'strata-vs-power-bi' },
      { label: 'Metabase', slug: 'strata-vs-metabase' },
      { label: 'Superset', slug: 'strata-vs-superset' },
    ],
    lineThem: 'They visualize your data.',
    lineStrata: 'Strata governs it, speeds it up, and makes it safe for AI.',
    rows: [
      { axis: 'Modeling', them: 'Configure every explore and combination', strata: 'Model by naming, convention over configuration' },
      { axis: 'Correctness', them: 'Blends can silently double count', strata: 'Grain-safe by construction' },
      { axis: 'Performance', them: 'Every refresh hits the warehouse', strata: 'Aggregate-aware, hot-tier routing' },
      { axis: 'AI', them: 'Bolt-on chat, not built for agents', strata: 'Agent-safe retrieval and NL resolution, native' },
    ],
  },
];

// Only link a chip when its comparison page actually exists.
const slugSet = new Set(comparisons.map((c) => c.slug));
---

<div class="mx-auto max-w-4xl">
  <!-- tabs -->
  <div role="tablist" aria-label="Compare Strata by category" class="mx-auto flex w-fit rounded-full border border-border bg-surface p-1">
    {tabs.map((t, i) => (
      <button
        role="tab"
        id={`stab-${t.key}`}
        data-stab={t.key}
        aria-controls={`spanel-${t.key}`}
        aria-selected={i === 0 ? 'true' : 'false'}
        tabindex={i === 0 ? 0 : -1}
        class="stab rounded-full px-5 py-2 text-sm font-semibold transition-colors"
      >
        {t.label}
      </button>
    ))}
  </div>

  <!-- panels -->
  {tabs.map((t, i) => (
    <div
      id={`spanel-${t.key}`}
      data-spanel={t.key}
      role="tabpanel"
      aria-labelledby={`stab-${t.key}`}
      hidden={i !== 0}
      class="mt-10"
    >
      {t.who.some((w) => slugSet.has(w.slug)) && (
        <>
          <div class="flex flex-wrap items-center justify-center gap-2">
            {t.who.filter((w) => slugSet.has(w.slug)).map((w) => (
              <a
                href={`/compare/${w.slug}/`}
                class="group inline-flex items-center gap-1 rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-muted-foreground transition-colors hover:border-primary hover:text-primary"
              >
                {w.label}
                <svg class="h-3 w-3 opacity-60 transition-transform group-hover:translate-x-0.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.17 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                </svg>
              </a>
            ))}
          </div>
          <p class="mt-3 text-center text-xs text-muted-foreground">Click a tool to see the full head-to-head with Strata.</p>
        </>
      )}

      <p class="mx-auto mt-6 max-w-2xl text-center font-display text-xl font-bold tracking-tight sm:text-2xl">
        <span class="text-muted-foreground">{t.lineThem}</span>{' '}
        <span class="text-primary">{t.lineStrata}</span>
      </p>

      <div class="mx-auto mt-10 max-w-3xl">
        <div class="hidden grid-cols-[7rem_1fr_1fr] gap-3 px-1 pb-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground sm:grid">
          <div></div>
          <div>Them</div>
          <div class="text-primary">Strata</div>
        </div>
        {t.rows.map((r) => (
          <div class="grid grid-cols-1 gap-3 border-t border-border py-4 sm:grid-cols-[7rem_1fr_1fr] sm:items-center">
            <div class="text-sm font-semibold text-foreground">{r.axis}</div>
            <div class="text-sm text-muted-foreground">{r.them}</div>
            <div class="rounded-md bg-primary/10 px-3 py-2 text-sm font-medium text-foreground">
              <span class="mr-1 font-bold text-primary">✓</span>{r.strata}
            </div>
          </div>
        ))}
      </div>

    </div>
  ))}

  <div class="mt-12 text-center">
    <p class="text-muted-foreground">See the difference on your own warehouse.</p>
    <CtaButton class="mt-5" />
  </div>
</div>

<style>
  .stab {
    color: var(--muted-foreground);
  }
  .stab[aria-selected='true'] {
    background: var(--primary);
    color: var(--primary-foreground);
  }
</style>

<script>
  const tabs = Array.from(document.querySelectorAll<HTMLButtonElement>('[data-stab]'));
  const panels = Array.from(document.querySelectorAll<HTMLElement>('[data-spanel]'));

  function activate(key: string, focus = false) {
    tabs.forEach((t) => {
      const on = t.dataset.stab === key;
      t.setAttribute('aria-selected', String(on));
      t.tabIndex = on ? 0 : -1;
      if (on && focus) t.focus();
    });
    panels.forEach((p) => {
      p.hidden = p.dataset.spanel !== key;
    });
  }

  tabs.forEach((t, i) => {
    t.addEventListener('click', () => activate(t.dataset.stab!));
    t.addEventListener('keydown', (e) => {
      if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
      e.preventDefault();
      const dir = e.key === 'ArrowRight' ? 1 : -1;
      const next = tabs[(i + dir + tabs.length) % tabs.length];
      activate(next.dataset.stab!, true);
    });
  });
</script>
