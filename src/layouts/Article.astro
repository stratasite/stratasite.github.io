---
import Base from './Base.astro';
import SectionScrollNav from '../components/SectionScrollNav.astro';
import CtaButton from '../components/CtaButton.astro';

interface Props {
  title: string;
  summary?: string;
  eyebrow?: string;
  sections?: { id: string; label: string }[];
  description?: string;
  // Optional lead media shown full-width under the header (video wins over image).
  // The summary above acts as its caption.
  video?: string;
  image?: string;
}

const { title, summary, eyebrow, sections = [], description, video, image } = Astro.props;
---

<Base title={`${title} — Strata`} description={description ?? summary}>
  <article class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <header class="mx-auto max-w-3xl text-center">
      {eyebrow && (
        <p class="font-display text-sm font-semibold uppercase tracking-wider text-primary">{eyebrow}</p>
      )}
      <h1 class="mt-3 text-4xl font-bold tracking-tight sm:text-5xl">{title}</h1>
      {summary && <p class="mt-5 text-lg text-muted-foreground">{summary}</p>}
    </header>

    {(video || image) && (
      <figure class="article-lead mx-auto mt-12 max-w-4xl">
        {video ? (
          <video
            class="article-lead-media w-full rounded-2xl"
            src={video}
            autoplay
            loop
            muted
            playsinline
            preload="metadata"
            aria-label={`${title} product demo`}
          />
        ) : (
          <img src={image} alt="" class="article-lead-media w-full rounded-2xl" loading="eager" />
        )}
      </figure>
    )}

    <div class={`mt-14 ${sections.length ? 'lg:grid lg:grid-cols-[1fr_15rem] lg:gap-12' : ''}`}>
      <!-- Content: MDX renders prose here; `.prose-strata` styles it. -->
      <div class="prose-strata mx-auto w-full max-w-3xl">
        <slot />

        <div class="mt-16 rounded-lg border border-border bg-surface-2 p-8 text-center not-prose">
          <h2 class="font-display text-2xl font-bold">See it on your own data</h2>
          <p class="mx-auto mt-2 max-w-xl text-muted-foreground">
            The fastest way to understand Strata is a live walkthrough against a warehouse like yours.
          </p>
          <CtaButton class="mt-6" />
        </div>
      </div>

      <!-- Optional right-side jump nav -->
      {sections.length > 0 && (
        <aside class="order-last">
          <SectionScrollNav sections={sections} />
        </aside>
      )}
    </div>
  </article>
</Base>

<style>
  /* Lead media floats on the rust page with a soft peach glow + depth shadow,
     matching the homepage feature row. */
  .article-lead-media {
    display: block;
    box-shadow:
      0 24px 50px -18px rgba(0, 0, 0, 0.5),
      0 0 90px 6px color-mix(in srgb, var(--strata-peach) 32%, transparent);
  }
</style>
