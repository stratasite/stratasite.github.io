---
/**
 * Shared template for every legal document — terms of use, privacy policy, and
 * the software licenses. New documents are MDX files in `src/content/legal/`;
 * nothing here should need to change to add one.
 *
 * Deliberately built on Base rather than Article: legal pages carry no demo CTA
 * and no marketing furniture, and they must print cleanly.
 */
import { getCollection } from 'astro:content';
import Base from './Base.astro';
import LegalToc from '../components/LegalToc.astro';

interface Props {
  title: string;
  summary: string;
  version: string;
  lastRevised: Date;
  effective?: Date;
  slug: string;
  description?: string;
  toc?: { id: string; label: string; text: string; depth: number }[];
}

const { title, summary, version, lastRevised, effective, slug, description, toc = [] } =
  Astro.props;

// Dates are authored as plain calendar dates (2026-07-22) and parsed as UTC
// midnight, so format in UTC — local formatting would shift them a day back.
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
    timeZone: 'UTC',
  });
const iso = (d: Date) => d.toISOString().slice(0, 10);

// Sibling documents, so any legal page is one click from all the others.
const siblings = (await getCollection('legal', ({ data }) => !data.draft))
  .filter((d) => d.slug !== slug)
  .sort((a, b) => a.data.order - b.data.order);
---

<Base title={`${title} — Strata`} description={description ?? summary}>
  <div class="mx-auto max-w-7xl px-4 py-14 sm:px-6 lg:px-8">
    <nav class="text-sm text-muted-foreground" aria-label="Breadcrumb">
      <a class="hover:text-foreground" href="/legal/">Legal</a>
      <span aria-hidden="true" class="px-1.5">/</span>
      <span class="text-foreground">{title}</span>
    </nav>

    <header class="mt-6 border-b border-border pb-8">
      <h1 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
      <p class="mt-4 max-w-2xl text-muted-foreground">{summary}</p>

      <dl class="mt-6 flex flex-wrap gap-x-10 gap-y-3 text-sm">
        <div>
          <dt class="font-display text-xs font-semibold uppercase tracking-wider text-primary">
            Version
          </dt>
          <dd class="tnum mt-1 text-foreground">{version}</dd>
        </div>
        <div>
          <dt class="font-display text-xs font-semibold uppercase tracking-wider text-primary">
            Last revised
          </dt>
          <dd class="mt-1 text-foreground">
            <time datetime={iso(lastRevised)}>{fmt(lastRevised)}</time>
          </dd>
        </div>
        {effective && (
          <div>
            <dt class="font-display text-xs font-semibold uppercase tracking-wider text-primary">
              Effective
            </dt>
            <dd class="mt-1 text-foreground">
              <time datetime={iso(effective)}>{fmt(effective)}</time>
            </dd>
          </div>
        )}
      </dl>
    </header>

    <div class={`mt-12 ${toc.length ? 'lg:grid lg:grid-cols-[16rem_1fr] lg:gap-14' : ''}`}>
      {toc.length > 0 && (
        <aside class="lg:order-first">
          <LegalToc toc={toc} />
        </aside>
      )}

      <div class="prose-strata prose-legal w-full max-w-3xl">
        <slot />

        {siblings.length > 0 && (
          <aside class="legal-siblings not-prose mt-16 border-t border-border pt-8">
            <h2 class="font-display text-sm font-semibold uppercase tracking-wider text-muted-foreground">
              Other legal documents
            </h2>
            <ul class="mt-4 space-y-2 text-sm">
              {siblings.map((d) => (
                <li>
                  <a class="text-primary hover:underline" href={`/legal/${d.slug}/`}>
                    {d.data.navLabel ?? d.data.title}
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )}
      </div>
    </div>
  </div>
</Base>

{/* Legal documents get printed, attached to contracts, and filed. On paper the
    site chrome is noise and the rust field is a waste of toner, so print plain
    black on white and drop everything that is not the document. */}
<style is:global>
  @media print {
    body {
      background: #fff !important;
      color: #000 !important;
    }
    header.sticky,
    footer,
    nav[aria-label='Contents'],
    nav[aria-label='Breadcrumb'],
    details,
    .legal-siblings {
      display: none !important;
    }
    main,
    main * {
      color: #000 !important;
      background: transparent !important;
      max-width: none !important;
    }
    .prose-legal h2,
    .prose-legal h3,
    .prose-legal h4 {
      break-after: avoid;
      page-break-after: avoid;
    }
    .prose-legal .legal-notice {
      border-left: 3px solid #000 !important;
    }
  }
</style>
