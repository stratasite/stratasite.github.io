---
/**
 * The legal hub — the one URL to hand out (`strata.do/legal/`) when something
 * outside the site needs to point at "the terms".
 */
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const docs = (await getCollection('legal', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);

// Document groups, in the order they appear on the page. A group with no
// documents yet is skipped, so licenses can land later without an edit here.
const groups = [
  {
    type: 'agreement' as const,
    title: 'Site and service terms',
    blurb: 'The terms that govern use of strata.do and the services offered on it.',
  },
  {
    type: 'privacy' as const,
    title: 'Privacy',
    blurb: 'How Strata collects, uses, and protects personal information.',
  },
  {
    type: 'license' as const,
    title: 'Software licenses',
    blurb: 'The license terms that come with the Strata software itself, by program.',
  },
].map((g) => ({ ...g, docs: docs.filter((d) => d.data.docType === g.type) }))
  .filter((g) => g.docs.length > 0);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });

const description =
  'Strata legal center: website terms of use, privacy policy, and the software license terms for Strata programs.';
---

<Base title="Legal — Strata" description={description}>
  <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <header class="max-w-2xl">
      <p class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-primary">Legal</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
        Terms, privacy, and licenses
      </h1>
      <p class="mt-5 text-muted-foreground">
        Every agreement that governs Strata, in one place. These links are permanent, so they are
        safe to reference from contracts, installers, and documentation. Each document carries a
        version and a revision date.
      </p>
    </header>

    {groups.map((group) => (
      <section class="mt-14">
        <h2 class="font-display text-2xl font-bold tracking-tight">{group.title}</h2>
        <p class="mt-2 max-w-2xl text-sm text-muted-foreground">{group.blurb}</p>

        <ul class="mt-6 grid gap-4 md:grid-cols-2">
          {group.docs.map((doc) => (
            <li>
              <a
                href={`/legal/${doc.slug}/`}
                class="flex h-full flex-col rounded-xl border border-border bg-surface p-6 transition-colors hover:border-primary"
              >
                <h3 class="font-display text-lg font-bold tracking-tight text-foreground">
                  {doc.data.title}
                </h3>
                <p class="mt-2 flex-1 text-sm text-muted-foreground">{doc.data.summary}</p>
                <p class="tnum mt-4 text-xs text-muted-foreground">
                  Version {doc.data.version} · Last revised {fmt(doc.data.lastRevised)}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <section class="mt-16 rounded-xl border border-border bg-surface-2 p-8">
      <h2 class="font-display text-xl font-bold tracking-tight">Questions or notices</h2>
      <p class="mt-2 max-w-2xl text-sm text-muted-foreground">
        Legal notices and questions about these documents go to
        <a class="text-primary hover:underline" href="mailto:info@strata.do">info@strata.do</a>, or by
        mail to Strata Business Intelligence, LLC, 9607 Podium Dr, Vienna, Virginia 22182. Privacy
        questions go to
        <a class="text-primary hover:underline" href="mailto:privacy@strata.do">privacy@strata.do</a>, and
        copyright infringement notices to
        <a class="text-primary hover:underline" href="mailto:copyright@strata.do">copyright@strata.do</a>.
      </p>
    </section>
  </div>
</Base>
