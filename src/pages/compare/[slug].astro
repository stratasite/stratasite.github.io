---
import { getCollection } from 'astro:content';
import Article from '../../layouts/Article.astro';
import VersusTable from '../../components/VersusTable.astro';

export async function getStaticPaths() {
  const entries = await getCollection('compare', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<Article
  eyebrow={`Strata vs ${entry.data.competitor}`}
  title={entry.data.title}
  summary={entry.data.summary}
  sections={[]}
>
  <Content />

  <h2>At a glance</h2>
  <div class="not-prose mt-6">
    <VersusTable slug={entry.slug} competitor={entry.data.competitor} />
  </div>
</Article>
