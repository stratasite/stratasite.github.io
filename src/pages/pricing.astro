---
import Base from '../layouts/Base.astro';
import CtaButton from '../components/CtaButton.astro';
import Callout from '../components/Callout.astro';
import { tiers, featureGroups } from '../data/pricing';

const title = 'Pricing — Strata';
const description =
  'Strata pricing: Free, Team, and Enterprise. Start free, scale governed self-service, and add SSO, row-level security, and airgapped deployment as you grow.';

// A qualifying checklist. The goal is to self-select teams that want broad,
// fast, non-technical and agent-ready self-service on their existing warehouse,
// and gently steer away teams who only want another tool for SQL-fluent analysts.
const fitChecklist = [
  {
    title: 'Do you want to put deep data in non-technical hands?',
    body: 'Your goal is to let business users curate their own datasets broadly across the whole model, not pick from a few prebuilt reports.',
  },
  {
    title: 'Do you need to open your data to AI agents safely?',
    body: 'You want agents to ask broad, cross-domain questions and get grain-safe answers, never confident wrong numbers.',
  },
  {
    title: 'Do you want to free your engineers from the ticket queue?',
    body: 'You want to offload everyday data requests to end users, so your technical team stops answering the same asks and reshaping data into one more custom cut for every report.',
  },
  {
    title: 'Do you need to trust every number?',
    body: 'You want answers that are correct by construction, where invalid, grain-crossing combinations are refused instead of quietly returning the wrong total.',
  },
  {
    title: 'Do you need sub-second speed for users and agents?',
    body: 'You need answers fast enough that people actually adopt self-service and agents can fire many queries per task.',
  },
  {
    title: 'Do you want data delivered into the tools your users already use?',
    body: 'You want the right data in users’ hands fast, inside the tools they already work in. Today that means Google Sheets, with more surfaces on the way.',
  },
];
---

<Base title={title} description={description}>
  <!-- HEADER -->
  <section class="border-b border-border">
    <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6 lg:px-8">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Pricing</p>
      <h1 class="mt-3 font-display text-4xl font-bold tracking-tight sm:text-5xl">
        Plans that scale with your team
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-muted-foreground">
        Start free and grow into governed, AI-safe self-service. Every plan starts with a quick demo on
        your own data.
      </p>
    </div>
  </section>

  <!-- TIERS: three self-contained columns, full offering in each -->
  <section>
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="grid items-stretch gap-6 md:grid-cols-3">
        {tiers.map((tier, ti) => (
          <div
            class={`flex flex-col rounded-2xl border p-8 ${
              tier.highlighted ? 'border-primary bg-surface ring-1 ring-primary' : 'border-border bg-surface'
            }`}
          >
            <div class="flex items-center justify-between gap-3">
              <h2 class="font-display text-2xl font-bold tracking-tight">{tier.name}</h2>
              {tier.highlighted && (
                <span class="rounded-full bg-primary px-3 py-1 text-xs font-bold uppercase tracking-wide text-primary-foreground">
                  Most popular
                </span>
              )}
            </div>
            <p class="mt-2 text-sm text-muted-foreground">{tier.tagline}</p>

            <dl class="mt-8 space-y-6">
              {featureGroups.map((group) => (
                <div>
                  <p class="text-xs font-semibold uppercase tracking-wider text-primary">{group.label}</p>
                  <div class="mt-3 space-y-2.5">
                    {group.rows.map((row) => (
                      <div class="flex items-start justify-between gap-4 text-sm">
                        <dt class="text-muted-foreground">{row.label}</dt>
                        <dd class="text-right font-medium">
                          {typeof row.values[ti] === 'string' ? (
                            <span class="text-foreground">{row.values[ti]}</span>
                          ) : row.values[ti] === true ? (
                            <svg class="h-5 w-5 text-primary" viewBox="0 0 20 20" fill="currentColor" aria-label="Included">
                              <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-7.5 7.5a1 1 0 01-1.4 0L3.3 10.7a1 1 0 011.4-1.4l3.8 3.8 6.8-6.8a1 1 0 011.4 0z" clip-rule="evenodd" />
                            </svg>
                          ) : row.values[ti] === false ? (
                            <svg class="h-4 w-4 text-muted-foreground/50" viewBox="0 0 20 20" fill="currentColor" aria-label="Not included">
                              <path fill-rule="evenodd" d="M4 9a1 1 0 100 2h12a1 1 0 100-2H4z" clip-rule="evenodd" />
                            </svg>
                          ) : (
                            <span class="text-muted-foreground/60" aria-label="Not applicable">—</span>
                          )}
                        </dd>
                      </div>
                    ))}
                  </div>
                </div>
              ))}
            </dl>

            <CtaButton variant={tier.highlighted ? 'primary' : 'ghost'} location={`pricing-${tier.key}`} class="mt-8 w-full" />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- QUALIFY: is Strata right for you? -->
  <section class="border-t border-border bg-surface-2">
    <div class="mx-auto max-w-5xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">Is Strata right for us?</h2>
        <p class="mt-4 text-muted-foreground">
          Strata is built for powerful, broad, fast self-service on the warehouse you already have. If
          you answer yes to these, you are in the right place:
        </p>
      </div>

      <ul class="mt-12 grid gap-x-8 gap-y-8 sm:grid-cols-2">
        {fitChecklist.map((item) => (
          <li class="flex items-start gap-4">
            <span class="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-primary text-primary-foreground">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 010 1.4l-7.5 7.5a1 1 0 01-1.4 0L3.3 10.7a1 1 0 011.4-1.4l3.8 3.8 6.8-6.8a1 1 0 011.4 0z" clip-rule="evenodd" />
              </svg>
            </span>
            <div>
              <h3 class="font-display text-lg font-bold tracking-tight text-foreground">{item.title}</h3>
              <p class="mt-1 text-sm text-muted-foreground">{item.body}</p>
            </div>
          </li>
        ))}
      </ul>

      <div class="mx-auto mt-14 max-w-2xl">
        <Callout type="tip" title="Not a fit? That is fair.">
          If all you want is another query tool for SQL-fluent analysts, Strata is not it. We are built to
          take powerful self-service to everyone else, the people who could never write the query in the
          first place.
        </Callout>
      </div>
    </div>
  </section>

  <!-- CLOSING CTA -->
  <section class="border-t border-border bg-strata-ink">
    <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl">Find the right plan for your team</h2>
      <p class="mt-4 text-muted-foreground">See Strata on your own data and we will help you pick the tier that fits.</p>
      <CtaButton location="pricing-closing" class="mt-8" />
    </div>
  </section>
</Base>
